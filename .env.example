# KTI-CF-WS-Worker environment
# This file documents secrets — never commit actual values.
#
# Set production secrets via wrangler CLI:
#   wrangler secret put INTERNAL_SECRET
#
# For local dev (wrangler dev), create a .dev.vars file (gitignored):
#   INTERNAL_SECRET=dev-only-secret-change-in-prod

INTERNAL_SECRET=change-me-in-production
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
